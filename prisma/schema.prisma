generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TradingAccount {
  id String @id @default(cuid())

  accountName String
  brokerName  String?

  propFirmName String?

  accountType String
  phase       String

  startingBalance Float
  currentBalance  Float

  maxDailyDrawdown   Float?
  maxOverallDrawdown Float?

  profitTarget Float?

  payoutCycle String?

  status String @default("Active")

  createdAt DateTime @default(now())

  trades Trade[]

  payouts Payout[]
}

model Trade {
  id String @id @default(cuid())

  accountId String?

  symbol    String
  direction String

  entryPrice Float
  stopLoss   Float?
  takeProfit Float?

  lotSize Float?

  riskPercent Float?

  pnl Float?
  rr  Float?

  commission Float?

  result String

  tradeDate DateTime  @default(now())
  closeDate DateTime?

  account TradingAccount? @relation(fields: [accountId], references: [id])

  notes String?

  tradeNotes TradeNote[]

  createdAt DateTime @default(now())
}

model TradeNote {
  id        String   @id @default(cuid())

  tradeId   String
  trade     Trade    @relation(fields: [tradeId], references: [id])

  setupType String?
  emotion   String?
  lesson    String?
  note      String?

  createdAt DateTime @default(now())
}

model Payout {
  id          String   @id @default(cuid())

  accountId   String
  account     TradingAccount @relation(fields: [accountId], references: [id])

  amount      Float

  requestDate DateTime @default(now())
  paidDate    DateTime?

  status      String   @default("Requested")

  notes       String?

  createdAt   DateTime @default(now())
}
